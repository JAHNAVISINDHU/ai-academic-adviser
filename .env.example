# ============================================================
# AI Academic Advisor - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Path for the SQLite database file inside the container
DB_PATH=/app/data/advisor_memory.db

# Path for the ChromaDB persistence directory inside the container
CHROMA_DB_PATH=/app/data/chroma_db

# Model to use for sentence embeddings (CPU-friendly, no GPU needed)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Optional: Claude API key for the agent (leave blank to use mock agent)
# ANTHROPIC_API_KEY=your_claude_api_key_here

# Optional: Ollama base URL for local LLM (alternative to Claude API)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3

# MCP Server configuration
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000
